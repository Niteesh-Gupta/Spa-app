# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (for migrations) ─────────────────────────────────────────────────
# Supabase dashboard → Settings → Database → URI mode
# Required only for running scripts/seed_users.js and scripts/migrate.js
DATABASE_URL=postgresql://postgres:[password]@db.your-ref.supabase.co:5432/postgres

# ── File storage ──────────────────────────────────────────────────────────────
# Local storage — PDFs written to this directory (relative to project root)
FILE_STORAGE_PATH=./uploads
